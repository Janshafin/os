#include <stdio.h>

int main(){

    int bt[20], rem_bt[20];
    int n, tq, i, time = 0;
    int wt[20], tat[20];

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++){
        printf("Burst time P%d: ",i+1);
        scanf("%d",&bt[i]);
        rem_bt[i] = bt[i];
    }

    printf("Enter time quantum: ");
    scanf("%d",&tq);

    int done;

    do{

        done = 1;

        for(i=0;i<n;i++){

            if(rem_bt[i] > 0){

                done = 0;

                if(rem_bt[i] > tq){

                    time += tq;
                    rem_bt[i] -= tq;

                }

                else{

                    time += rem_bt[i];
                    wt[i] = time - bt[i];
                    rem_bt[i] = 0;
                }
            }
        }

    }while(!done);

    for(i=0;i<n;i++)
        tat[i] = wt[i] + bt[i];

    printf("\nProcess\tBT\tWT\tTAT\n");

    for(i=0;i<n;i++)
        printf("P%d\t%d\t%d\t%d\n",i+1,bt[i],wt[i],tat[i]);

    return 0;
}
