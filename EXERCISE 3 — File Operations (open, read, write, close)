#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <unistd.h>

#define BUFFER_SIZE 1024

int main() {

    int fd = open("example.txt", O_RDWR | O_CREAT, 0777);

    if (fd == -1) {
        perror("open");
        exit(1);
    }

    char buffer[BUFFER_SIZE];
    ssize_t bytesRead;

    printf("Reading from the file:\n");

    while ((bytesRead = read(fd, buffer, sizeof(buffer))) > 0) {
        write(STDOUT_FILENO, buffer, bytesRead);
    }

    if (bytesRead == -1) {
        perror("read");
        close(fd);
        return 1;
    }

    close(fd);

    printf("\nFile operations completed successfully.\n");

    return 0;
}
