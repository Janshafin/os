#include <stdio.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <string.h>

int main() {

    int shmid;
    char *str;

    shmid = shmget((key_t)2345, 1024, 0666 | IPC_CREAT);

    str = (char*) shmat(shmid,(void*)0,0);

    printf("Write Data: ");
    fgets(str,100,stdin);

    printf("Data written in memory: %s",str);

    shmdt(str);

    return 0;
}
